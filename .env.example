# OpenAI-compatible provider. Copy this file to .env and replace the placeholders.
OPENAI_API_KEY=your_openai_compatible_api_key
OPENAI_BASE_URL=https://aihubmix.com/v1
MODEL_NAME=your_model_id

# Optional TFTAgent behavior.
TFT_AGENT_LLM_MODE=auto
TFT_AGENT_LLM_TIMEOUT_MS=3000
TFT_AGENT_LLM_TEMPERATURE=0
TFT_AGENT_LLM_MAX_TOKENS=500

# Optional evidence-backed conclusion generation (disabled by default)
TFT_AGENT_CONCLUSION_MODE=off
TFT_AGENT_CONCLUSION_PROVIDER=openai_compatible
TFT_AGENT_CONCLUSION_MODEL=
TFT_AGENT_CONCLUSION_ENDPOINT=
TFT_AGENT_CONCLUSION_API_KEY=
TFT_AGENT_CONCLUSION_TIMEOUT_MS=1800
TFT_AGENT_CONCLUSION_MAX_OUTPUT_TOKENS=350
TFT_AGENT_CONCLUSION_MAX_CORRECTIONS=3
TFT_AGENT_CONCLUSION_THINKING=
TFT_AGENT_CONCLUSION_REASONING_EFFORT=minimal
TFT_AGENT_LLM_RESPONSE_FORMAT=1

# Optional persistent semantic index. The preferred AIHubMix-compatible base URL
# is used here because it is more reliable on networks where aihubmix.com fails.
TFT_AGENT_EMBEDDING_MODE=off
TFT_AGENT_EMBEDDING_PROVIDER=openai_compatible
TFT_AGENT_EMBEDDING_ENDPOINT=https://api.inferera.com/v1
TFT_AGENT_EMBEDDING_MODEL=text-embedding-3-small
TFT_AGENT_EMBEDDING_DIMENSIONS=1536
TFT_AGENT_EMBEDDING_API_KEY=
TFT_AGENT_EMBEDDING_BATCH_SIZE=64
TFT_AGENT_EMBEDDING_TIMEOUT_MS=30000
TFT_AGENT_SEMANTIC_INDEX_PATH=.cache/semantic-index.sqlite
TFT_AGENT_OFFICIAL_CATALOG_TIMEOUT_MS=10000
