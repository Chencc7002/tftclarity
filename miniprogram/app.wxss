page {
  height: 100%;
  color: #18243a;
  background: #f4f8fc;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  box-sizing: border-box;
}

button::after {
  border: 0;
}

.safe-page {
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.app-navigation {
  flex: none;
  box-sizing: content-box;
  display: flex;
  align-items: center;
  color: #ffffff;
  background: linear-gradient(118deg, #25a9c7, #4d7fe2 58%, #7556c7);
  box-shadow: 0 8rpx 28rpx rgba(39, 84, 151, .18);
}

.nav-content {
  width: 100%;
  height: 100%;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.brand-star {
  width: 54rpx;
  height: 54rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, .72);
  border-radius: 18rpx;
  font-size: 34rpx;
  box-shadow: 0 0 24rpx rgba(255, 255, 255, .26);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 760;
  letter-spacing: .5rpx;
}

.nav-subtitle {
  margin-left: 14rpx;
  padding: 6rpx 12rpx;
  border: 1rpx solid rgba(255, 255, 255, .34);
  border-radius: 999rpx;
  color: rgba(255, 255, 255, .9);
  font-size: 20rpx;
}
