# Public hostname. Example: tft.example.com
DOMAIN=tft.example.com

# Generate with: openssl rand -base64 48
TFT_AGENT_VISITOR_SECRET=CHANGE_ME

# Anonymous AI budgets. One real provider request consumes one use.
TFT_AGENT_VISITOR_DAILY_LLM_LIMIT=1
TFT_AGENT_IP_DAILY_LLM_LIMIT=5
TFT_AGENT_GLOBAL_DAILY_LLM_LIMIT=50
TFT_AGENT_REQUESTS_PER_MINUTE=30

# Optional structured parsing LLM. Keep "never" to launch without this cost.
TFT_AGENT_LLM_MODE=never
# TFT_AGENT_LLM_PROVIDER=chat
# TFT_AGENT_LLM_ENDPOINT=https://your-provider.example/v1/chat/completions
# TFT_AGENT_LLM_MODEL=your-model
# TFT_AGENT_LLM_API_KEY=replace-me
# TFT_AGENT_LLM_TIMEOUT_MS=1500

# Persistent semantic vector index. Build it with: npm run semantic:index
# The endpoint may be an OpenAI-compatible /v1 base URL or a full /embeddings URL.
TFT_AGENT_EMBEDDING_MODE=off
# TFT_AGENT_EMBEDDING_PROVIDER=openai_compatible
# TFT_AGENT_EMBEDDING_ENDPOINT=https://your-provider.example/v1
# TFT_AGENT_EMBEDDING_MODEL=your-embedding-model
# TFT_AGENT_EMBEDDING_API_KEY=replace-me
# TFT_AGENT_EMBEDDING_DIMENSIONS=1024
# TFT_AGENT_EMBEDDING_TIMEOUT_MS=8000
# TFT_AGENT_EMBEDDING_BATCH_SIZE=64
TFT_AGENT_SEMANTIC_INDEX_PATH=.cache/semantic-index.sqlite
TFT_AGENT_SEMANTIC_LOCALE=zh-CN

# Optional evidence-backed answer generation. Keep "off" to launch without it.
TFT_AGENT_CONCLUSION_MODE=off
# TFT_AGENT_CONCLUSION_PROVIDER=openai_compatible
# TFT_AGENT_CONCLUSION_ENDPOINT=https://your-provider.example/v1
# TFT_AGENT_CONCLUSION_MODEL=your-model
# TFT_AGENT_CONCLUSION_API_KEY=replace-me
# TFT_AGENT_CONCLUSION_TIMEOUT_MS=1800
# TFT_AGENT_CONCLUSION_MAX_OUTPUT_TOKENS=350
# TFT_AGENT_CONCLUSION_MAX_CORRECTIONS=2
# TFT_AGENT_CONCLUSION_MAX_VALIDATION_ERRORS=8
# TFT_AGENT_CONCLUSION_MAX_TRANSPORT_RETRIES=1

TFT_AGENT_EXPLORER_TIMEOUT_MS=2200
TFT_AGENT_CATALOG_TIMEOUT_MS=2200
TFT_AGENT_COMPS_TIMEOUT_MS=2200
