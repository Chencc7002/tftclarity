{
  "name": "tft-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TFT in-game data retrieval agent core for MetaTFT item build queries.",
  "scripts": {
    "start": "node src/app/small-window-server.js",
    "window": "powershell -ExecutionPolicy Bypass -File scripts/start-small-window.ps1",
    "window:server": "powershell -ExecutionPolicy Bypass -File scripts/start-small-window.ps1 -NoBrowser",
    "test": "node --test",
    "smoke": "node test/mvp-query.test.js",
    "smoke:small-window": "node scripts/smoke-small-window.mjs",
    "smoke:practical": "node scripts/smoke-second-round-practical.mjs",
    "smoke:visual": "node scripts/smoke-small-window-visual.mjs",
    "visual:fixture-server": "node scripts/visual-fixture-server.mjs",
    "smoke:hotkey": "powershell -ExecutionPolicy Bypass -File scripts/smoke-small-window-hotkey.ps1",
    "smoke:metatft": "node scripts/smoke-metatft.mjs",
    "smoke:comps": "node scripts/smoke-comp-rankings.mjs",
    "smoke:comps:live": "node scripts/smoke-comp-rankings-live.mjs",
    "smoke:trend-page:live": "node scripts/smoke-comp-trend-page-live.mjs",
    "check:trend-gate": "node scripts/check-official-comp-trend-gate.mjs",
    "verify:trend-goal": "node scripts/verify-comp-trend-goal.mjs",
    "smoke:sqlite": "node scripts/smoke-sqlite-cache.mjs",
    "backup:sqlite": "node scripts/backup-sqlite.mjs",
    "smoke:llm": "node scripts/smoke-llm.mjs",
    "smoke:conclusion-llm": "node scripts/smoke-conclusion-llm.mjs",
    "semantic:index": "node scripts/build-semantic-index.mjs",
    "semantic:audit": "node scripts/audit-semantic-index.mjs",
    "smoke:item-localization": "node scripts/refresh-item-localization.mjs --remote --check --strict-localization",
    "refresh:item-localization": "node scripts/refresh-item-localization.mjs",
    "audit:aliases": "node scripts/audit-alias-coverage.mjs",
    "audit:items": "node scripts/audit-item-availability.mjs",
    "audit:item-patch": "node scripts/audit-item-patch.mjs",
    "maintain:comp-profiles": "node scripts/apply-comp-profile-maintenance.mjs --write",
    "refresh:assets": "node scripts/refresh-asset-manifest.mjs",
    "audit:assets": "node scripts/refresh-asset-manifest.mjs --check"
  },
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
